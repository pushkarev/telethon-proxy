[Unit]
Description=OpenClaw Usage Dashboard
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/.openclaw/workspace
Environment=USAGE_DASHBOARD_PORT=8789
Environment=USAGE_DASHBOARD_BASE_PATH=/usage-dashboard
ExecStart=/usr/bin/python3 /home/ubuntu/.openclaw/workspace/dashboard/usage_app.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
