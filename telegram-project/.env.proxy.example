# Real upstream Telegram account credentials
TG_API_ID=
TG_API_HASH=
TG_PHONE=

# Session file for the upstream account used by the proxy
TP_UPSTREAM_SESSION=sessions/proxy_upstream

# Downstream-facing proxy app identity (for the future MTProto facade)
TP_DOWNSTREAM_API_ID=900000
TP_DOWNSTREAM_API_HASH=dev-proxy-change-me

# Proxy listener
TP_LISTEN_HOST=127.0.0.1
TP_LISTEN_PORT=9000

# Folder policy
TP_CLOUD_FOLDER=Cloud
TP_ALLOW_MEMBER_LISTING=1
TP_UPDATE_BUFFER_SIZE=1000
