{
  "name": "telethon-proxy-desktop",
  "private": true,
  "version": "0.1.1",
  "description": "Desktop app for the local Telegram, WhatsApp, and Messages MCP bridge.",
  "type": "module",
  "main": "electron/main.mjs",
  "productName": "Telethon Proxy",
  "scripts": {
    "app:dev": "electron .",
    "app:pack": "electron-builder --dir",
    "app:dist": "electron-builder",
    "app:smoke": "node scripts/electron-smoke.mjs",
    "browser:run": "node scripts/playwright-runner.mjs",
    "browser:shot": "node scripts/playwright-runner.mjs --screenshot"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "dev.telethon.proxy",
    "productName": "Telethon Proxy",
    "afterSign": "electron/notarize.mjs",
    "files": [
      "electron/**/*",
      "telegram-project/webui/**/*",
      "whatsapp-project/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist/electron"
    },
    "mac": {
      "identity": "Developer ID Application",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.inherit.plist",
      "extendInfo": {
        "LSUIElement": true
      },
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "playwright": "^1.58.2",
    "qrcode": "^1.5.4",
    "telegram": "^2.26.22"
  }
}
