{
  "name": "telethon-proxy-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop shell and background service packaging for the local Telethon proxy.",
  "type": "module",
  "main": "electron/main.mjs",
  "productName": "Telethon Proxy",
  "scripts": {
    "app:dev": "electron .",
    "app:bundle-python": "sh ./scripts/build-python-service.sh",
    "app:pack": "npm run app:bundle-python && electron-builder --dir",
    "app:dist": "npm run app:bundle-python && electron-builder",
    "app:smoke": "node scripts/electron-smoke.mjs",
    "browser:run": "node scripts/playwright-runner.mjs",
    "browser:shot": "node scripts/playwright-runner.mjs --screenshot"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "dev.telethon.proxy",
    "productName": "Telethon Proxy",
    "files": [
      "electron/**/*",
      "telegram-project/webui/**/*",
      "whatsapp-project/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/background",
        "to": "background",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "dist/electron"
    },
    "mac": {
      "extendInfo": {
        "LSUIElement": true
      },
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "playwright": "^1.58.2",
    "qrcode": "^1.5.4"
  }
}
