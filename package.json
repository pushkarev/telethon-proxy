{
  "name": "aardvark-desktop",
  "private": true,
  "version": "0.1.2",
  "description": "Aardvark desktop app for the local Telegram, WhatsApp, and Messages MCP bridge.",
  "author": "PushPlayLabs Inc",
  "type": "module",
  "main": "electron/main.mjs",
  "productName": "Aardvark",
  "scripts": {
    "app:dev": "electron .",
    "app:pack": "electron-builder --dir",
    "app:dist": "electron-builder",
    "app:smoke": "node scripts/electron-smoke.mjs",
    "check": "node --check electron/main.mjs && node --check electron/native-backend.mjs && node --check electron/preview-cache.mjs && node --check electron/filesystem-bridge.mjs && node --check electron/gramjs-background.mjs && node --check whatsapp-project/service.mjs && node --check telegram-project/webui/app.js",
    "test": "node --test electron/native-backend.test.mjs electron/preview-cache.test.mjs electron/filesystem-bridge.test.mjs electron/gramjs-background.test.mjs whatsapp-project/service.test.mjs",
    "browser:run": "node scripts/playwright-runner.mjs",
    "browser:shot": "node scripts/playwright-runner.mjs --screenshot"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "dev.telethon.proxy",
    "productName": "Aardvark",
    "afterSign": "electron/notarize.mjs",
    "files": [
      "electron/**/*",
      "telegram-project/webui/**/*",
      "whatsapp-project/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist/electron"
    },
    "mac": {
      "icon": "electron/assets/aardvark.icns",
      "identity": "Developer ID Application",
      "timestamp": "http://timestamp.apple.com/ts01",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.inherit.plist",
      "extendInfo": {
        "LSUIElement": true
      },
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "playwright": "^1.58.2",
    "qrcode": "^1.5.4",
    "telegram": "^2.26.22"
  }
}
